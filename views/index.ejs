<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="icon" type="image/png" href="/images/logo_circular.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/cinematic.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollToPlugin.min.js"></script>
    <script src="https://kit.fontawesome.com/4ac2a8d541.js" crossorigin="anonymous"></script>
</head>

<body>
    <button id="backToTop" class="backToTop">
        <svg class="svgIcon" viewBox="0 0 384 512">
            <path
                d="M214.6 41.4c-12.5-12.5-32.8-12.5-45.3 0l-160 160c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0L160 141.2V448c0 17.7 14.3 32 32 32s32-14.3 32-32V141.2L329.4 246.6c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3l-160-160z">
            </path>
        </svg>
    </button>
    <section class="hero">
        <!-- Sky Background -->
        <div class="layer sky" data-layer-name="sky" data-depth="0"></div>

        <!-- Starfield Canvas -->
        <canvas id="starfield" class="layer" data-depth="0.05"></canvas>

        <!-- Dynamic Asset Layers Container -->
        <div id="dynamic-layers"></div>

        <div class="water-fade"></div>

        <!-- Hero Content -->
        <div class="hero-content">
            <h1 class="hero-title">Dũng Nguyễn</h1>
            <h2 class="hero-subtitle">Fullstack JavaScript Developer</h2>
            <p class="hero-description">
                Building modern web apps with Vue, Node.js, and scalable architecture.
            </p>
            <button class="cta-button">View My Experience</button>
        </div>

        <div class='scrolldown'>
            <div class="chevrons">
                <div class='chevrondown'></div>
                <div class='chevrondown'></div>
            </div>
        </div>
    </section>
    <section id="aboutme">
        <div class="content-card">
            <div class="section2-title">
                <h2>About Me</h2>
                <h2>About Me</h2>
            </div>
            <div class="card-text">
                <p>I engineer immersive web systems where motion, architecture, and performance work as one.
                </p>

                <p>My work focuses on building structured animation frameworks, parallax depth systems, and
                    high-performance
                    interactive interfaces — not just visual effects, but scalable motion architecture.</p>

                <p>
                    With experience across frontend rendering layers and backend logic design, I approach
                    projects holistically:
                    clean structure, optimized queries, controlled state, and fluid interaction.
                </p>

                <p>Every detail is intentional.</p>
                <p>Every motion has purpose.</p>
                <p>Every system is built to scale.</p>
            </div>
        </div>
    </section>
    <section id="skills">
        <div class="json-background">
            <pre id="json-code"></pre>
        </div>
        <div class="section2-title expertise">
            <h2>My Expertise</h2>
            <h2>My Expertise</h2>
        </div>
        <div class="flex-content">
            <div class="container-fluid">
                <div class="row expertise-row">
                    <div class="col-sm-12 col-lg-4 mb-4">
                        <div class="card-container">
                            <div class="card">
                                <div class="front-content">
                                    <p class="heading">Back-end Development</p>
                                    <svg xmlns="http://www.w3.org/2000/svg" x="0px" y="0px" width="100" height="100"
                                        viewBox="0 0 48 48">
                                        <path fill="#21a366"
                                            d="M24.007,45.419c-0.574,0-1.143-0.15-1.646-0.44l-5.24-3.103c-0.783-0.438-0.401-0.593-0.143-0.682 c1.044-0.365,1.255-0.448,2.369-1.081c0.117-0.067,0.27-0.043,0.39,0.028l4.026,2.389c0.145,0.079,0.352,0.079,0.486,0l15.697-9.061 c0.145-0.083,0.24-0.251,0.24-0.424V14.932c0-0.181-0.094-0.342-0.243-0.432L24.253,5.446c-0.145-0.086-0.338-0.086-0.483,0 L8.082,14.499c-0.152,0.086-0.249,0.255-0.249,0.428v18.114c0,0.173,0.094,0.338,0.244,0.42l4.299,2.483 c2.334,1.167,3.76-0.208,3.76-1.591V16.476c0-0.255,0.2-0.452,0.456-0.452h1.988c0.248,0,0.452,0.196,0.452,0.452v17.886 c0,3.112-1.697,4.9-4.648,4.9c-0.908,0-1.623,0-3.619-0.982l-4.118-2.373C5.629,35.317,5,34.216,5,33.042V14.928 c0-1.179,0.629-2.279,1.646-2.861L22.36,3.002c0.994-0.562,2.314-0.562,3.301,0l15.694,9.069C42.367,12.656,43,13.753,43,14.932 v18.114c0,1.175-0.633,2.271-1.646,2.861L25.66,44.971c-0.503,0.291-1.073,0.44-1.654,0.44">
                                        </path>
                                        <path fill="#21a366"
                                            d="M28.856,32.937c-6.868,0-8.308-3.153-8.308-5.797c0-0.251,0.203-0.452,0.455-0.452h2.028 c0.224,0,0.413,0.163,0.448,0.384c0.306,2.066,1.218,3.108,5.371,3.108c3.308,0,4.715-0.747,4.715-2.502 c0-1.01-0.401-1.76-5.54-2.263c-4.299-0.424-6.955-1.371-6.955-4.809c0-3.167,2.672-5.053,7.147-5.053 c5.026,0,7.517,1.745,7.831,5.493c0.012,0.13-0.035,0.255-0.122,0.35c-0.086,0.09-0.208,0.145-0.334,0.145h-2.039 c-0.212,0-0.397-0.149-0.44-0.354c-0.491-2.173-1.678-2.868-4.904-2.868c-3.611,0-4.031,1.257-4.031,2.2 c0,1.143,0.495,1.477,5.367,2.122c4.825,0.64,7.116,1.544,7.116,4.935c0,3.418-2.853,5.379-7.827,5.379">
                                        </path>
                                    </svg>
                                </div>
                                <div class="content">
                                    <h4>Node.js</h4>
                                    <p>
                                        Experience with Express & NestJS. Build RESTful APIs, handle middleware, errors,
                                        logging, WebSockets, and JWT/OAuth authentication.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-sm-12 col-lg-4 mb-4">
                        <div class="card-container">
                            <div class="card">
                                <div class="front-content">
                                    <p class="heading">Front-end Development</p>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="100px" height="100px"
                                        viewBox="0 0 256 221" fill="none">
                                        <path fill="#41B883" d="M204.8 0H256L128 220.8L0 0H51.2L128 132.8L204.8 0Z">
                                        </path>
                                        <path fill="#35495E" d="M51.2 0H128L192 110.4L128 220.8L51.2 0Z"></path>
                                    </svg>
                                </div>
                                <div class="content">
                                    <h4>Vue.js</h4>
                                    <p>
                                        Build responsive SPAs with Vue. Experience with Vue Router, Vuex,
                                        component-based architecture, and Vue CLI.
                                    </p>

                                    <h4>Frontend Development</h4>
                                    <p>
                                        HTML5, CSS3, Bootstrap, JavaScript/TypeScript. Skilled in Flexbox, Grid, and DOM
                                        manipulation.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-sm-12 col-lg-4 mb-4">
                        <div class="card-container">
                            <div class="card">
                                <div class="front-content">
                                    <p class="heading">Database</p>
                                    <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"
                                        fill="#6666FF" version="1.1" id="Capa_1" width="100px" height="100px"
                                        viewBox="0 0 548.29 548.291" xml:space="preserve">
                                        <g>
                                            <g>
                                                <path
                                                    d="M276.043,244.216c-24.575,0-38.741,24.087-38.741,53.862c-0.241,30.228,14.407,53.382,38.5,53.382 c24.323,0,38.512-22.92,38.512-54.091C314.313,268.303,300.604,244.216,276.043,244.216z" />
                                                <path
                                                    d="M486.2,196.116h-13.164V132.59c0-0.399-0.064-0.795-0.116-1.2c-0.021-2.52-0.824-4.997-2.551-6.96L364.656,3.677 c-0.031-0.031-0.064-0.044-0.085-0.075c-0.629-0.704-1.364-1.29-2.141-1.796c-0.231-0.154-0.462-0.283-0.704-0.419 c-0.672-0.365-1.386-0.672-2.121-0.893c-0.199-0.052-0.377-0.134-0.576-0.186C358.229,0.118,357.4,0,356.562,0H96.757 C84.893,0,75.256,9.649,75.256,21.502v174.613H62.093c-16.967,0-30.733,13.756-30.733,30.733v159.812 c0,16.961,13.766,30.731,30.733,30.731h13.163V526.79c0,11.854,9.637,21.501,21.501,21.501h354.777 c11.853,0,21.502-9.647,21.502-21.501V417.392H486.2c16.977,0,30.729-13.771,30.729-30.731V226.849 C516.93,209.872,503.177,196.116,486.2,196.116z M96.757,21.502h249.053v110.006c0,5.943,4.818,10.751,10.751,10.751h94.973 v53.861H96.757V21.502z M353.033,376.96l-10.394,27.884c-22.666-6.619-41.565-13.479-62.828-22.445 c-3.527-1.418-7.317-2.132-11.094-2.362c-35.909-2.352-69.449-28.819-69.449-80.778c0-47.711,30.236-83.623,77.71-83.623 c48.675,0,75.351,36.854,75.351,80.317c0,36.142-16.766,61.638-37.785,71.091v0.945 C326.828,371.528,340.519,374.367,353.033,376.96z M72.912,370.116l7.328-29.764c9.69,4.96,24.554,9.915,39.917,9.915 c16.525,0,25.271-6.84,25.271-17.228c0-9.928-7.56-15.597-26.691-22.442c-26.457-9.217-43.696-23.858-43.696-47.014 c0-27.163,22.68-47.948,60.231-47.948c17.954,0,31.184,3.791,40.623,8.03l-8.021,29.061c-6.375-3.076-17.711-7.564-33.3-7.564 c-15.599,0-23.163,7.079-23.163,15.357c0,10.15,8.977,14.646,29.533,22.447c28.108,10.394,41.332,25.023,41.332,47.464 c0,26.699-20.557,49.365-64.253,49.365C99.844,379.785,81.899,375.06,72.912,370.116z M451.534,520.962H96.757v-103.57h354.777 V520.962z M475.387,377.428h-99.455V218.231h36.158v128.97h63.297V377.428z" />
                                            </g>
                                        </g>
                                    </svg>
                                </div>
                                <div class="content">
                                    <h4>SQL & NoSQL</h4>
                                    <p>
                                        Write complex queries, stored procedures, indexing optimization. Understand
                                        ACID, transactions, and database design (normalization/denormalization).
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <section id="experience"></section>
    <section id="career-contacts">
        <div class="container-fluid">
            <div class="row career-contacts-mb">
                <div class="col-sm-6 col-mgb">
                    <div class="contacts">
                        <div class="section2-title expertise">
                            <h2>Contact me</h2>
                            <h2>Contact me</h2>
                        </div>
                        <form class="form" id="contacts-form">
                            <input class="input" type="text" id="name" placeholder="Name">
                            <div class="input-group">
                                <input class="input" type="text" id="email" placeholder="E-Mail I.D.">
                                <div id="tooltip-error" class="invalid-tooltip">
                                    Vui lòng bao gồm '@' trong địa chỉ email.
                                </div>
                            </div>
                            <textarea class="textarea" id="message" placeholder="Enter message"></textarea>
                            <center><button class="button">Submit</button></center>
                        </form>
                    </div>
                </div>
                <div class="col-sm-6 col-mgb">
                    <div class="career">
                        <div class="section2-title expertise">
                            <h2>My Career</h2>
                            <h2>My Career</h2>
                        </div>
                        <div class="accordion" id="accordionExample">
                            <div class="accordion-item">
                                <h2 class="accordion-header" id="headingOne">
                                    <button class="accordion-button" type="button" data-bs-toggle="collapse"
                                        data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                                        <div class="accordion-button-header">
                                            <div>Fullstack Developer</div>
                                            <div>08/2022 - 03/2025</div>
                                        </div>
                                    </button>
                                </h2>
                                <div id="collapseOne" class="accordion-collapse collapse show"
                                    aria-labelledby="headingOne" data-bs-parent="#accordionExample">
                                    <div class="accordion-body">
                                        <div class="accordion-company">
                                            <span class="company-location"><i
                                                    class="fa-solid fa-location-dot location-icon"></i>HCM city</span>
                                            <span class="company-name"><i
                                                    class="fa-solid fa-building"></i>atsolutions</span>
                                        </div>
                                        <span class="accordion-contents">
                                            <ul>
                                                <li>Architected and implemented a web software solution using **Node.js
                                                    (ExpressJS)** and **EJS**, meeting specific customer needs.</li>
                                                <li>Streamlined business processes by developing and maintaining the
                                                    **SAP ByDesign** system, enhancing operational efficiency.</li>
                                            </ul>
                                        </span>
                                        <div class="use-language">
                                            <div class="language-item">ABSL</div>
                                            <div class="language-item">NodeJS</div>
                                            <div class="language-item">Javascript</div>
                                            <div class="language-item">MySQL</div>
                                            <div class="language-item">MSSQL</div>
                                            <div class="language-item">...</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="accordion-item">
                                <h2 class="accordion-header" id="headingTwo">
                                    <button class="accordion-button" type="button" data-bs-toggle="collapse"
                                        data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                                        <div class="accordion-button-header">
                                            <div>Freelancer</div>
                                            <div>03/2025 - present</div>
                                        </div>
                                    </button>
                                </h2>
                                <div id="collapseTwo" class="accordion-collapse collapse" aria-labelledby="headingTwo"
                                    data-bs-parent="#accordionExample">
                                    <div class="accordion-body">
                                        <div class="accordion-company">
                                            <span class="company-name"><i class="fa-solid fa-house-laptop"></i>FREELANCE
                                                | REMOTE</span>
                                        </div>
                                        <span class="accordion-contents">
                                            <ul>
                                                <li>Developed end-to-end e-commerce solutions, covering both front-end
                                                    and back-end, using Node.js (ExpressJS), VueJS and modern
                                                    technologies.</li>
                                                <li>Integrated payment gateways, order management systems, and custom
                                                    shopping cart features to optimize the user's shopping experience.
                                                </li>
                                            </ul>
                                        </span>
                                        <div class="use-language">
                                            <div class="language-item">NodeJS</div>
                                            <div class="language-item">VueJS</div>
                                            <div class="language-item">Javascript</div>
                                            <div class="language-item">MySQL</div>
                                            <div class="language-item">MSSQL</div>
                                            <div class="language-item">...</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <footer class="footer-section">
        <p class="footer-cta">Let's build something great together.</p>
        <div class="footer-content">
            <div class="social-links">
                <a href="<%= info.linkedin %>" title="LinkedIn" class="social-link" target="_blank" rel="noopener">
                    <i class="fa-brands fa-linkedin"></i>
                </a>

                <a href="<%= info.facebook %>" title="Facebook" class="social-link" target="_blank" rel="noopener">
                    <i class="fa-brands fa-square-facebook"></i>
                </a>

                <a href="<%= info.github %>" title="GitHub" class="social-link" target="_blank" rel="noopener">
                    <i class="fa-brands fa-square-github"></i>
                </a>
            </div>

            <div class="footer-note">
                Nguyễn Nguyên Dũng © <%= new Date().getFullYear() %>
            </div>
        </div>
    </footer>
    <div class="modal fade" id="contactSuccessModal" tabindex="-1" aria-labelledby="contactSuccessLabel"
        aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="contactSuccessLabel"><i class="fa-solid fa-circle-check"></i><span>
                            Success</span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Your message has been sent successfully!
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary button" data-bs-dismiss="modal">OK</button>
                </div>
            </div>
        </div>
    </div>
    <script src="/js/script.js"></script>
    <script src="/js/parallax.js"></script>
    <script type="module" src="/js/gsapanimation.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>